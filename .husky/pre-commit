#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Skip pre-commit for users with GitHub web interface emails (users.noreply.github.com)
# These users are committing from GitHub web and can't run local hooks
CURRENT_EMAIL=$(git config user.email)
if echo "$CURRENT_EMAIL" | grep -q "@users\.noreply\.github\.com"; then
  echo "Skipping pre-commit hooks for GitHub web user: $CURRENT_EMAIL"
  exit 0
fi

npm run lint 
npm run test-version
